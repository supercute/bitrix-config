{
    "name": "supercute/bitrix-config",
    "description": "Configuration for 1C Bitrix",
    "type": "library",
    "license": "BSD-3-Clause",
    "keywords": [
        "1c bitrix",
        "bitrix",
        "env",
        "config"
    ],
    "autoload": {
        "psr-4": {
            "Supercute\\BitrixConfig\\": "src/"
        },
        "files": [
            "src/functions.php"
        ]
    },
    "authors": [
        {
            "name": "Danil Shumskikh",
            "email": "d@shumskikh.ru"
        }
    ],
    "require": {
        "vlucas/phpdotenv": "^v5.6.3"
    },
    "autoload-dev": {
        "psr-4": {
            "Supercute\\BitrixConfig\\Tests\\": "tests/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "rector/rector": "^2.5",
        "friendsofphp/php-cs-fixer": "^3.95"
    },
    "scripts": {
        "test": "phpunit",
        "fix": "php-cs-fixer fix",
        "lint": [
            "php-cs-fixer fix --dry-run --diff",
            "phpstan analyse"
        ]
    }
}
